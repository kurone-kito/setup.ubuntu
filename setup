#!/bin/sh
# -*- mode: sh -*-
# vim: set ft=sh :

set -eu
cd "$(cd "$(dirname "$0")"; pwd)"

sudo apt-get update
sudo apt-get -y upgrade
sudo apt-get install -y --no-install-recommends atomicparsley awscli bash \
  bash-completion bat broot build-essential bzip3 ca-certificates cloc \
  cmake curl di dialog editorconfig fastfetch ffmpeg fzf gh gist git \
  git-delta gnupg groff htop hx imagemagick jq libarchive-tools \
  libvips-tools links mdp mkcert mosh nano neovim node-playwright nodejs \
  nkf nyancat onedrive openapi p7zip pandoc procps python3 python3-ollama \
  openssh-client owncloud-client-cmd pinentry-tty podman rename rsync \
  screen shellcheck sl sqlite3 sshfs sylpheed tarship thefuck tmux tor \
  trash-cli unzip util-linux vim vit w3m wget2 wireguard x264 x265 \
  xz-utils yq yt-dlp zip zsh zsh-theme-powerlevel9k
sudo apt-get autoremove -y --purge

sudo apt remove \
  $(dpkg --get-selections docker.io docker-compose docker-doc podman-docker containerd runc | cut -f1)
sudo install -m 0755 -d /etc/apt/keyrings
sudo curl -fsSL https://download.docker.com/linux/debian/gpg \
  -o /etc/apt/keyrings/docker.asc
sudo chmod a+r /etc/apt/keyrings/docker.asc

sudo tee /etc/apt/sources.list.d/docker.sources <<EOF
Types: deb
URIs: https://download.docker.com/linux/debian
Suites: $(. /etc/os-release && echo "$VERSION_CODENAME")
Components: stable
Signed-By: /etc/apt/keyrings/docker.asc
EOF

sudo apt-get update
sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
sudo groupadd docker || true
sudo usermod -aG docker "$USER"
newgrp docker

find_brew() {
  if command -v brew >/dev/null 2>&1
  then
    command -v brew
    return 0
  fi
  for p in \
    /opt/homebrew/bin/brew \
    /usr/local/bin/brew \
    "${HOME}/.linuxbrew/bin/brew" \
    /home/linuxbrew/.linuxbrew/bin/brew
  do
    [ -x "$p" ] && {
      echo "$p"
      return 0
    }
  done
  return 1
}

if ! find_brew >/dev/null 2>&1
then
  NONINTERACTIVE=1 /bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  if [ -f "${HOME}/.bashrc" ]
  then
    echo "eval \"\$($(find_brew) shellenv)\"" >> "${HOME}/.bashrc"
  fi
fi
if [ -f "${HOME}/.bashrc" ]
then
  # shellcheck disable=SC1091
  . "${HOME}/.bashrc" || true
fi
eval "$("$(find_brew)" shellenv)"
if [ -f Brewfile ]
then
  brew bundle --file=Brewfile
fi
brew update
if [ -f "${HOME}/.bashrc" ]
then
  # shellcheck disable=SC1091
  . "${HOME}/.bashrc" || true
fi

echo done.
